APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Singapore
APP_URL=http://localhost

# --- Vercel (required or you get HTTP 500 / MissingAppKeyException) ---
# APP_KEY=base64:...   (run `php artisan key:generate` locally; add the same variable for Production, Preview, and Development in Vercel)
# APP_URL=https://your-project.vercel.app
# APP_ENV=production
# APP_DEBUG=false
# Neon vars are injected by the integration (POSTGRES_URL, etc.). `bootstrap/vercel-env.php` strips newlines and
# removes `channel_binding` from Postgres URIs before Laravel reads config (pdo_pgsql + Vercel).

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

HASH_DRIVER=argon2id

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql

# --- Neon (Vercel Native / Marketplace) — recommended ---
# Vercel injects the same names Neon shows in the dashboard. Laravel uses the first URL found:
#   DB_URL → DATABASE_URL → POSTGRES_URL → SUPABASE_DB_URL
#
# Pooled URL (hostname contains “-pooler”): use for the app and for Vercel serverless.
DATABASE_URL="postgresql://USER:PASSWORD@ep-your-branch-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
#
# Unpooled / direct (no “-pooler”): optional; use for `php artisan migrate` if the pooler misbehaves.
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-your-branch.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
#
# If Neon gives `channel_binding=require` and PHP cannot connect, try the same URI without that query param.
# Optional for some poolers: DB_PGSQL_EMULATE_PREPARES=true
#
# When DATABASE_URL is set, you normally omit DB_HOST / DB_PORT / DB_DATABASE / DB_USERNAME / DB_PASSWORD (avoid conflicts).
DB_SSLMODE=require
# DB_SCHEMA=public
# DB_PGSQL_EMULATE_PREPARES=false

# Vercel/Neon may also define these (Laravel reads POSTGRES_URL if DATABASE_URL is empty):
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_PRISMA_URL=
# POSTGRES_USER=
# POSTGRES_HOST=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=

# --- Local or discrete host/port (no single URL) ---
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=utilities
# DB_USERNAME=postgres
# DB_PASSWORD=

# --- Supabase + Vercel ---
# Use the Supavisor pooler URI on Vercel (IPv4); avoid raw db.*:5432 direct if the platform is IPv4-only.
# https://supabase.com/docs/guides/troubleshooting/supabase--your-network-ipv4-and-ipv6-compatibility-cHe3BP
# SUPABASE_DB_URL=

# Docs: https://vercel.com/docs/postgres — `vercel env pull .env.local` for local copies of Vercel secrets.

# On Vercel, `bootstrap/vercel-env.php` forces cookie + array cache if these would be `database` (avoids 500s when `sessions` / `cache` tables are missing).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
